{
  "name": "format-workshop-mvp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "sync:ffmpeg": "node scripts/sync-ffmpeg.mjs",
    "predev": "pnpm sync:ffmpeg",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prebuild": "pnpm sync:ffmpeg",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "0.12.15",
    "@ffmpeg/util": "0.12.2",
    "fflate": "0.8.2",
    "lucide": "1.8.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "6.1.200"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
